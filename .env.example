# Turso SQLite databáze — https://turso.tech (free tier)
# 1. Vytvořte účet na turso.tech
# 2. Vytvořte databázi: turso db create chatazlatehory
# 3. Spusťte: bun run db:init
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Heslo pro admin panel na /admin/
ADMIN_PASSWORD=zvolte-silne-heslo
